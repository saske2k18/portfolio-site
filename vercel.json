{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    { "source": "/admin.html", "destination": "/public/admin.html" },
    { "source": "/admin.js", "destination": "/public/admin.js" },
    { "source": "/admin.css", "destination": "/public/admin.css" },
    { "source": "/app.js", "destination": "/public/app.js" },
    { "source": "/style.css", "destination": "/public/style.css" },
    { "source": "/config.js", "destination": "/public/config.js" },
    { "source": "/uploads/(.*)", "destination": "/uploads/$1" },
    { "source": "/(.*)", "destination": "/public/index.html" }
  ]
}
